datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  
  orderId      String   @id
  value        Float
  creationDate DateTime
  items        Item[]
}

model Item {
  id        Int    @id @default(autoincrement())
  productId Int
  quantity  Int
  price     Float
  order     Order  @relation(fields: [orderId], references: [orderId])
  orderId   String
}